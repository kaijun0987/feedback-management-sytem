# 复制为 `.env`：pnpm 会合并 `.env` 与各 mode 下的 `.env.<mode>`
# 开发命令 `pnpm dev` 使用 `vite --mode test`，会再加载 `.env.test`（若存在）

# 应用 public path（子目录部署须以 / 结尾，如 /admin/）
VITE_BASE_URL=/

# 页面标题与描述
VITE_APP_TITLE=反馈中心
VITE_APP_DESC=公司内部反馈系统

# 图标前缀（勿改，除非明确调整图标方案）
VITE_ICON_PREFIX=icon
VITE_ICON_LOCAL_PREFIX=icon-local

# 权限路由：static | dynamic
VITE_AUTH_ROUTE_MODE=static
# 静态路由模式下的登录后首页
VITE_ROUTE_HOME=home

VITE_MENU_ICON=mdi:menu

# 开发环境是否走 Vite 代理（Y/N）
VITE_HTTP_PROXY=Y

# 路由：hash | history | memory
VITE_ROUTER_HISTORY_MODE=history

# 后端成功业务码
VITE_SERVICE_SUCCESS_CODE=0000

# 需登出/弹窗登出/刷新 token 的业务码，逗号分隔
VITE_SERVICE_LOGOUT_CODES=8888,8889
VITE_SERVICE_MODAL_LOGOUT_CODES=7777,7778
VITE_SERVICE_EXPIRED_TOKEN_CODES=9999,9998,3333

# 静态权限模式下的超管角色名（与后端/种子用户角色一致）
VITE_STATIC_SUPER_ROLE=R_SUPER

VITE_SOURCE_MAP=N
VITE_STORAGE_PREFIX=SOY_
VITE_AUTOMATICALLY_DETECT_UPDATE=Y
VITE_PROXY_LOG=Y
VITE_DEVTOOLS_LAUNCH_EDITOR=code

# 默认主服务根地址；可与 `.env.test` 中项合并覆盖
# 对接本地 Nest feedback-api 时（见 README）
VITE_SERVICE_BASE_URL=http://127.0.0.1:3001

# 其它多服务：JSON/JSON5 字符串。key 会映射为代理路径 `/proxy-<key>`
# 其中 `feedback` 应对应 feedback-api 的 `base path`（默认 /api 前缀在 nginx 与本地一致时）
VITE_OTHER_SERVICE_BASE_URL={"demo":"http://localhost:9528","feedback":"http://127.0.0.1:3001/api"}
