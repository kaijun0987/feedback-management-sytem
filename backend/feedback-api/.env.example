# 复制为 `backend/feedback-api/.env` 后根据本机修改

# PostgreSQL 连接串（可用 docker compose 中默认账号/库名作起点）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/soybean_feedback?schema=public"

# HTTP 端口
PORT=3001

# JWT 签名密钥（请换成随机长串，勿提交到公开仓库）
JWT_SECRET="replace-with-a-secure-secret"

# 每用户-每表单的提交关联 HMAC 密钥（可与 JWT_SECRET 不同；匿名仅隐藏展示，后端仍可审计）
FEEDBACK_SUBMISSION_HMAC_SECRET="replace-with-a-different-secure-secret"
