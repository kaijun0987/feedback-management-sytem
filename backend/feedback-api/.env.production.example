# Elastic Beanstalk production environment variables

DATABASE_URL="postgresql://<user>:<password>@<rds-endpoint>:5432/soybean_feedback?schema=public"
PORT=8080
NODE_ENV=production
JWT_SECRET="replace-with-a-long-random-secret"
FEEDBACK_SUBMISSION_HMAC_SECRET="replace-with-a-different-long-random-secret"
CORS_ALLOWED_ORIGINS="https://kaijun-feedback-system.fipdev.com"
